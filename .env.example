# GAAP — Governed Autonomous AI Platform
#
# Copy to .env and fill in. Leave the Postgres/Redis values empty to run
# locally with SQLite + in-memory backends (single `uvicorn` command).
# See docs/ADOPTION.md for a friendly walkthrough of every setting.

# --- Environment: production | local | test ---
APP_ENV=local

# --- AI models (provider-agnostic; bring your own keys) ---
# Providers per role: anthropic | google | openai
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-gemini-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# Planner — heavy reasoning
PLANNER_PROVIDER=anthropic
PLANNER_MODEL=claude-opus-4-8
# Policy/compliance — fast + cheap
POLICY_PROVIDER=anthropic
POLICY_MODEL=claude-haiku-4-5
# Summaries — best-effort, degrades gracefully
SUMMARY_PROVIDER=google
SUMMARY_MODEL=gemini-2.0-flash

# --- Knowledge (RAG) ---
# EMBEDDING_PROVIDER=local runs on a local ONNX model — no key, no quota.
EMBEDDING_PROVIDER=local
INGEST_ON_STARTUP=true

# --- Service dependency graph (GraphRAG blast-radius, Neo4j) ---
# Set true for the full experience; false runs on runbooks alone.
GRAPH_ENABLED=false
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=gaapgraph123

# --- Persistence (empty = local SQLite) ---
# DATABASE_URL=postgresql+asyncpg://gaap:gaap@postgres:5432/gaap
# CHECKPOINTER_URL=postgresql://gaap:gaap@postgres:5432/gaap

# --- Redis (empty = in-memory event bus + inline task execution) ---
# REDIS_URL=redis://redis:6379/0

# --- Auth (JWT) ---
# JWT_SECRET is REQUIRED in production. Left empty locally, an ephemeral one is generated.
JWT_SECRET=
JWT_EXPIRE_MINUTES=60
BOOTSTRAP_ADMIN_EMAIL=admin@local
BOOTSTRAP_ADMIN_PASSWORD=changeme

# --- Execution boundary: mock | kubernetes ---
EXECUTION_BACKEND=mock
K8S_NAMESPACE=default
K8S_IN_CLUSTER=false
# K8S_KUBECONFIG=/path/to/kubeconfig

# --- Security / ops ---
ALLOWED_ORIGINS=*
RATE_LIMIT=120/minute
ENABLE_METRICS=true

# --- LangSmith Tracing (optional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=contract-bound-autonomy

# --- General ---
LOG_LEVEL=INFO
