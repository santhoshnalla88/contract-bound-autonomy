# Contract-Bound Autonomous Remediation Orchestrator
#
# Copy to .env and fill in. Leave the Postgres/Redis values empty to run
# locally with SQLite + in-memory backends (single `uvicorn` command).

# --- Environment: production | local | test ---
APP_ENV=local

# --- LLM Provider ---
OPENAI_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
EMBEDDING_MODEL=text-embedding-3-small

# --- Persistence (empty = local SQLite) ---
# DATABASE_URL=postgresql+asyncpg://gaap:gaap@postgres:5432/gaap
# CHECKPOINTER_URL=postgresql://gaap:gaap@postgres:5432/gaap

# --- Redis (empty = in-memory event bus + inline task execution) ---
# REDIS_URL=redis://redis:6379/0

# --- Auth (JWT) ---
# JWT_SECRET is REQUIRED in production. Left empty locally, an ephemeral one is generated.
JWT_SECRET=
JWT_EXPIRE_MINUTES=60
BOOTSTRAP_ADMIN_EMAIL=admin@local
BOOTSTRAP_ADMIN_PASSWORD=changeme

# --- Execution boundary: mock | kubernetes ---
EXECUTION_BACKEND=mock
K8S_NAMESPACE=default
K8S_IN_CLUSTER=false
# K8S_KUBECONFIG=/path/to/kubeconfig

# --- Security / ops ---
ALLOWED_ORIGINS=*
RATE_LIMIT=120/minute
ENABLE_METRICS=true

# --- LangSmith Tracing (optional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=contract-bound-autonomy

# --- General ---
LOG_LEVEL=INFO
